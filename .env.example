# =============================================================================
# AI Financial Decision System — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# AWS (Forensic + Decision Agents — Claude 3.5 Sonnet via Bedrock)
# 1. Create an IAM User with AmazonBedrockFullAccess
# 2. Request model access for Claude 3.5 Sonnet in the Bedrock console
# 3. Generate Access Key ID + Secret Access Key in IAM
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Google Cloud (Macro CIO Agent — Gemini 2.0 Flash via Vertex AI)
# 1. Create project "Financial-Decision-Machine" in Google Cloud Console
# 2. Enable the Vertex AI API
# 3. Create a Service Account with "Vertex AI User" role
# 4. Download JSON key file and set path below
# -----------------------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/gcp-service-account-key.json
GOOGLE_CLOUD_PROJECT=financial-decision-machine
GOOGLE_CLOUD_LOCATION=us-central1

# -----------------------------------------------------------------------------
# OpenRouter (Asymmetry Agent — DeepSeek Chat)
# Sign up at openrouter.ai and add credits (~$10 to start)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=

# -----------------------------------------------------------------------------
# Financial Modeling Prep (Market Data + Earnings Transcripts)
# Requires a plan that includes "Earnings Call Transcripts"
# Sign up at financialmodelingprep.com
# -----------------------------------------------------------------------------
FMP_API_KEY=

# -----------------------------------------------------------------------------
# Supabase (Persistent Decision Storage)
# 1. Create a project at supabase.com
# 2. Run supabase/migrations/001_create_decisions_table.sql
# 3. Copy Project URL and service_role key (Settings > API)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Next.js Frontend (public vars — safe to expose to browser)
# These must be prefixed NEXT_PUBLIC_ to be available client-side
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Backend Orchestrator URL (used by Next.js API routes)
# Local dev: http://localhost:8000
# Production: URL of your deployed FastAPI service
# -----------------------------------------------------------------------------
ORCHESTRATOR_URL=http://localhost:8000
